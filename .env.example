# Copy to .env and fill in. .env is gitignored.
# OpenAI-compatible endpoint (append /v1):
#   外网: https://llm-center.ali.modelbest.cn/llm/v1
#   内网: https://llm-center.ali.modelbest.co/llm/v1
LLM_BASE_URL=https://llm-center.ali.modelbest.cn/llm/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-flash

# Verifier uses a DIFFERENT model than the solver (independent cross-check).
# Defaults to the "other" cheap model automatically; override here if needed.
# VERIFIER_MODEL=deepseek-v4-flash
# VERIFIER_BASE_URL=   # defaults to LLM_BASE_URL
# VERIFIER_API_KEY=    # defaults to LLM_API_KEY
